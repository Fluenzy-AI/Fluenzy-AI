generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  User
  Admin
  Modaretor
  SUPER_ADMIN
  COLLEGE_ADMIN
  PORTAL_ADMIN
  PORTAL_HR
}

// ─── Portal Staff Role ────────────────────────────────────────────────────
enum PortalRole {
  ADMIN
  HR
}

enum PortalStaffStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  LOCKED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  INTERVIEWED
  SELECTED
  OFFER_SENT
  ONBOARDED
  REJECTED
  WITHDRAWN
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PortalEmailStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

enum CollegeAdminStatus {
  PENDING    // Awaiting superadmin approval
  APPROVED
  REJECTED
  SUSPENDED
}

enum CollegeStudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum Plan {
  Free
  Standard
  Pro
  Enterprise
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ─── OTP Verification (Signup & 2FA) ────────────────────────────────────────
model OtpVerification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  otp         String
  type        String   @default("signup") // "signup" | "login_2fa"
  attempts    Int      @default(0)
  expiresAt   DateTime
  verified    Boolean  @default(false)
  // Pending user data (stored until OTP verified for signup)
  pendingName     String?
  pendingPassword String? // already hashed

  createdAt   DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model users {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String   @unique
  password         String?
  avatar           String?
  stripeCustomerId String?
  plan             Plan     @default(Free)
  role             Role     @default(User)
  usageCount       Int      @default(0)
  usageLimit       Int      @default(3)
  // Training module usage counters
  englishUsage     Int      @default(0)
  dailyUsage       Int      @default(0)
  hrUsage          Int      @default(0)
  technicalUsage   Int      @default(0)
  companyUsage     Int      @default(0)
  mockUsage        Int      @default(0)
  gdCoachUsage    Int      @default(0)  // GD Coach - separate from GD Agent
  gdUsage         Int      @default(0)
  interviewGuideUsage Int   @default(0)
  
  // Billing & Renewal fields
  renewalDate      DateTime?
  billingCycle     String?  // monthly, annual
  lastUsageReset   DateTime? // Track when usage was last reset
  
  disabled         Boolean  @default(false)
  sessions         Session[]
  lessonProgress   LessonProgress[]
  hrProgress       HRProgress[]
  gdProgress       GDProgress[]
  resumes          Resume[]
  loginLogs        UserLoginLog[]
  couponUsages     CouponUsage[]
  paymentHistories PaymentHistory[]
  profile          UserProfile?
  subscriptions    subscriptions[]
  monthlyUsages   MonthlyUsage[]
  gdQueue          GDQueue[]
  gdParticipants   GDParticipant[]
  gdHistory        GDHistory[]
  notifications    Notification[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserProfile {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String   @unique @db.ObjectId
  user                 users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  username             String   @unique
  headline             String?
  bio                  String?
  socialLinks          Json?
  openToWork           Boolean  @default(false)
  publicProfileEnabled Boolean  @default(false)
  publicSections       Json?
  skills               Skill[]
  experiences          Experience[]
  educations           Education[]
  certifications       Certification[]
  projects             Project[]
  courses              Course[]
  languages            Language[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Skill {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  level       String
  createdAt   DateTime @default(now())
}

model Experience {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role        String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime @default(now())
}

model Education {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  degree      String
  institution String
  startYear   Int
  endYear     Int?
  grade       String?
  createdAt   DateTime @default(now())
}

model Certification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  issuer      String
  issueDate   DateTime
  imageUrl    String?
  credentialUrl String?
  skills      String[]
  createdAt   DateTime @default(now())
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?
  techStack   String?
  projectUrl  String?
  repoUrl     String?
  createdAt   DateTime @default(now())
}

model Course {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  platform    String
  status      String
  createdAt   DateTime @default(now())
}

model Language {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  profileId   String   @db.ObjectId
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  proficiency String
  createdAt   DateTime @default(now())
}

model subscriptions {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String   @db.ObjectId
  user                 users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String
  stripeCustomerId     String
  plan                 Plan     @default(Pro)
  status               String   @default("active") // active, failed, cancelled, expired
  currentPeriodEnd     DateTime?
  autoRenew            Boolean  @default(true)
  paymentMethod        String?
  invoiceId            String?
  amount               Float?
  discountAmount       Float    @default(0)
  couponUsed           String?  // coupon code
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Session {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId      String   @unique
  userId         String   @db.ObjectId
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module         String
  targetCompany  String?
  role           String?
  startTime      DateTime @default(now())
  endTime        DateTime?
  duration       Int? // in minutes
  aggregateScore Float?
  status         String? // PASS or FAIL
  resumeId       String? @db.ObjectId
  resume         Resume? @relation(fields: [resumeId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  transcripts    Transcript[]
}

model Transcript {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId               String   @db.ObjectId
  session                 Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turnNumber              Int
  aiPrompt                String
  userAnswer              String // raw speech-to-text
  aiFeedback              String
  idealAnswer             String
  clarityScore            Float?
  relevanceScore          Float?
  grammarScore            Float?
  confidenceScore         Float?
  technicalAccuracyScore  Float?
  perQuestionScore        Float?
  createdAt               DateTime @default(now())
}

model LessonProgress {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  score        Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, lessonId])
}

model HRProgress {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  score        Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, lessonId])
}

model GDProgress {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  score        Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, lessonId])
}

model Resume {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  uploadedAt  DateTime @default(now())
  sessions    Session[]
}

model UserLoginLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginTime       DateTime
  logoutTime      DateTime?
  sessionDuration Int? // in seconds
  ip              String?
  location        String? // country/city
  deviceType      String? // Mobile, Laptop, Tablet, Desktop
  os              String? // Android, iOS, Windows, macOS, Linux
  browser         String? // Chrome, Safari, etc.
  status          String   @default("success") // success, failed
  createdAt       DateTime @default(now())
}

model Coupon {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  code            String       @unique
  discountType    DiscountType
  discountValue   Float
  maxUsage        Int?
  perUserLimit    Int          @default(1)
  usedCount       Int          @default(0)
  startDate       DateTime?
  expiryDate      DateTime?
  applicablePlans String[]     // e.g. ["Pro", "Enterprise"]
  status          String       @default("active") // active, inactive, expired
  createdBy       String       @db.ObjectId // superadmin user id
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  usages          CouponUsage[]
}

model CouponUsage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  couponId       String   @db.ObjectId
  userId         String   @db.ObjectId
  appliedPlan    String?
  originalPrice  Float?
  discountAmount Float    @default(0)
  finalPrice     Float?
  couponCode     String?
  appliedAt      DateTime? @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
}

model PaymentHistory {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId     String?
  orderId       String?
  plan          String?
  billingCycle  String?
  paymentCurrency String?
  originalAmount Float?
  discountAmount Float    @default(0)
  finalAmount   Float
  paymentMethod String?
  invoiceId     String?
  status        String   // paid, failed, refunded, free_via_coupon
  couponUsed    String?  // coupon code
  couponType    String?  // percentage, flat
  date          DateTime @default(now())
  receipt       Receipt?
}

model Receipt {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  paymentHistoryId String   @db.ObjectId
  paymentHistory   PaymentHistory @relation(fields: [paymentHistoryId], references: [id], onDelete: Cascade)
  userId           String   @db.ObjectId
  orderId          String?
  paymentId        String?
  invoiceNumber    String
  currency         String   @default("INR")
  billingCycle     String?
  plan             String?
  originalAmount   Float?
  discountAmount   Float    @default(0)
  finalAmount      Float
  couponCode       String?
  couponType       String?
  discountValue    Float?
  issuedAt         DateTime @default(now())
  validFrom        DateTime?
  validTill        DateTime?
  receiptUrl       String?
  snapshot         Json?

  @@unique([paymentHistoryId])
}

model PlanPricing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  plan        Plan     @unique
  name        String   // Display name
  price       Float    @default(0) // Monthly price
  annualPrice Float?   // Annual price (optional discount)
  currency    String   @default("INR")
  status      String   @default("active") // active, disabled
  
  // Module-specific limits (JSON for flexibility)
  moduleLimits Json?    // { english: 2, hr: 2, gd: 2, technical: 2, company: 2, mock: 2, daily: 2, interviewGuide: 1 }
  
  // Razorpay alignment
  razorpayPlanId String? // Razorpay plan ID for subscription management
  razorpayPriceId String? // Razorpay price/item ID
  
  // Usage tracking
  isUnlimited   Boolean  @default(false)
  
  // Legacy fields (kept for backward compatibility during transition)
  totalMonthlyLimit Int  @default(0) // Total sessions per month
  
  // Billing cycle
  billingCycleDays Int  @default(30) // Default 30 days
  
  updatedBy   String?  @db.ObjectId
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model GlobalPlanSettings {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  plan          Plan     @unique
  monthlyLimit  Int?
  isUnlimited   Boolean  @default(false)
  status        String   @default("active") // active, disabled
  lastReset     DateTime @default(now())
  updatedBy     String?  @db.ObjectId
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// Monthly usage tracking per billing cycle
model MonthlyUsage {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingMonth    Int      // Month (1-12)
  billingYear     Int      // Year (e.g., 2026)
  billingCycleStart DateTime // Start of the billing cycle
  billingCycleEnd   DateTime // End of the billing cycle
  
  // Module usage counts for this month
  englishUsage     Int      @default(0)
  dailyUsage       Int      @default(0)
  hrUsage          Int      @default(0)
  technicalUsage   Int      @default(0)
  companyUsage     Int      @default(0)
  mockUsage        Int      @default(0)
  gdCoachUsage    Int      @default(0)  // GD Coach - separate from GD Agent
  gdUsage         Int      @default(0)  // GD Agent (AI Agents, Private GD, Random Matching)
  interviewGuideUsage Int   @default(0)
  
  // Total usage for the month
  totalUsage       Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Composite unique constraint to ensure one record per user per month
  @@unique([userId, billingMonth, billingYear])
  @@index([userId, billingYear, billingMonth])
}

// Razorpay webhook events for audit trail
model RazorpayWebhookEvent {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  eventType       String   // payment.authorized, subscription.activated, subscription.renewed, etc.
  webhookId       String   @unique // Razorpay's webhook ID
  paymentId       String?
  subscriptionId  String?
  customerId      String?
  plan            String?
  status          String?
  amount          Float?
  currency        String?
  
  // Event data
  payload         Json     // Raw webhook payload
  processed       Boolean  @default(false)
  processedAt     DateTime?
  errorMessage    String?
  
  createdAt       DateTime @default(now())
  
  @@index([eventType])
  @@index([subscriptionId])
  @@index([processed, createdAt])
}

model InterviewGuide {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @db.ObjectId
  targetRole         String
  targetCompany      String?
  experienceLevel    String   // Fresher or Experienced
  communicationLevel String   // Beginner, Intermediate, Advanced
  jobDescription     String?  // Full job description (optional for backward compatibility)
  generatedContent   Json     // Full guide JSON
  pdfUrl             String?  // Generated PDF URL (optional)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ==================== GD SYSTEM MODELS ====================

enum GDRole {
  Initiator
  Moderator
  Analyzer
  Challenger
  Supporter
  InfoProvider
  Summarizer
  Opposer
}

enum GDMode {
  Corporate
  CurrentAffairs
  Abstract
  BusinessEthics
  Technology
  Random
}

enum GDDifficulty {
  Easy
  Medium
  Hard
}

enum GDPhase {
  Waiting      // Waiting for participants
  Initiation   // Initiator starts
  Discussion   // Open discussion
  Analysis     // Conflict & analysis
  Summary      // Summarizer concludes
  Completed    // Session ended
}

enum ParticipantStatus {
  Queued       // Waiting in queue
  Joining      // Joining room
  Active       // In session
  Left         // Left session
  Expired      // Session expired
}

// Users waiting in matchmaking queue
model GDQueue {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  participantCount Int    // 3-8 participants desired
  difficulty     GDDifficulty @default(Medium)
  mode           GDMode   @default(Random)
  status         ParticipantStatus @default(Queued)
  joinedAt       DateTime @default(now())
  matchedAt      DateTime?
  
  @@index([status, participantCount, difficulty, mode])
}

// Active GD Sessions
model GDSession {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  channelName    String   @unique // Agora channel name (UUID)
  topic          String
  topicCategory  GDMode
  difficulty     GDDifficulty
  phase          GDPhase  @default(Waiting)
  phaseStartedAt DateTime @default(now())
  duration       Int      @default(0) // in seconds
  maxDuration    Int      @default(1200) // 20 minutes max
  createdAt      DateTime @default(now())
  endedAt        DateTime?
  
  participants  GDParticipant[]
  analytics     GDAnalytics?
  transcript    GDTranscript[]
  history       GDHistory[]
  
}

// Participants in a GD session
model GDParticipant {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId      String   @db.ObjectId
  session        GDSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId         String   @db.ObjectId
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           GDRole
  order          Int      // Speaking order
  joinedAt       DateTime @default(now())
  leftAt         DateTime?
  status         ParticipantStatus @default(Active)
  
  analytics     GDAnalytics?
  
  @@unique([sessionId, userId])
  @@index([sessionId])
}

// Real-time analytics per participant
model GDAnalytics {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId            String   @unique @db.ObjectId
  session              GDSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId        String?  @unique @db.ObjectId
  participant          GDParticipant? @relation(fields: [participantId], references: [id], onDelete: Cascade)
  
  // Speaking analytics
  speakingTime         Int      @default(0) // in seconds
  totalSpeakingTime    Int      @default(0)
  interruptions        Int      @default(0)
  silenceDuration      Int      @default(0)
  
  // Quality metrics
  confidenceScore      Float    @default(0)
  paceScore            Float    @default(0) // WPM
  fillerWordCount      Int      @default(0)
  volumeStability      Float    @default(0)
  
  // Role performance
  rolePerformanceScore Float    @default(0)
  
  // Raw data for post-processing
  speakingEvents       Json?    // Array of speaking intervals
  volumeData           Json?    // Volume levels over time
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Session transcript
model GDTranscript {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId    String   @db.ObjectId
  session      GDSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantId String  @db.ObjectId
  speakerName  String
  role         GDRole
  content      String
  timestamp    Float    // in seconds from session start
  phase        GDPhase
  
  @@index([sessionId])
}

// GD History for users
model GDHistory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId      String   @db.ObjectId
  session        GDSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  topic          String
  topicCategory  GDMode
  role           GDRole
  duration       Int      // in seconds
  
  // Scores
  overallScore   Float?
  communicationScore Float?
  confidenceScore Float?
  grammarScore   Float?
  relevanceScore Float?
  leadershipScore Float?
  roleScore      Float?
  
  // Analysis
  strengths      String[]
  improvements   String[]
  
  // Transcript
  transcriptUrl  String?
  
  createdAt      DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

// Stored topics for variety
model GDTopic {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  content        String
  category       GDMode
  difficulty     GDDifficulty
  usageCount     Int      @default(0)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  
  @@index([category, difficulty])
}

// Latest topics asked by companies (managed by Super Admin)
model LatestTopic {
  id                            String   @id @default(auto()) @map("_id") @db.ObjectId
  companyName                   String

  // GD
  gdTopic                       String?
  gdQuestion                    String?
  gdDifficulty                  String?  // Easy, Medium, Hard

  // Personal Interview
  personalInterviewTopic        String?
  personalInterviewQuestion     String?
  personalInterviewDifficulty   String?

  // Technical Interview
  technicalInterviewTopic       String?
  technicalInterviewQuestion    String?
  technicalInterviewDifficulty  String?

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([companyName])
  @@index([createdAt])
}

// ==================== COLLEGE / UNIVERSITY ADMIN SYSTEM ====================

model CollegeAdmin {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  collegeName       String
  adminName         String
  email             String              @unique
  password          String
  designation       String
  contactNumber     String
  domain            String              // e.g. gla.ac.in
  logoUrl           String?
  address           String?
  website           String?
  status            CollegeAdminStatus  @default(PENDING)
  approvedBy        String?             @db.ObjectId  // superadmin id
  approvedAt        DateTime?
  rejectionReason   String?

  // Plan allocation
  totalSeats        Int                 @default(0)
  usedSeats         Int                 @default(0)
  allocatedPlan     Plan                @default(Free)
  planExpiresAt     DateTime?
  moduleLimits      Json?               // per-module limits for students

  // Billing
  billedCentrally   Boolean             @default(true)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  students          CollegeStudent[]
  batches           CollegeBatch[]
  otpRecords        CollegeOtpVerification[]
  paymentHistories  CollegePaymentHistory[]
  transactions      CollegeTransaction[]

  @@index([domain])
  @@index([status])
}

model CollegeOtpVerification {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String
  otp             String
  type            String    @default("college_signup") // "college_signup" | "college_login_2fa"
  attempts        Int       @default(0)
  expiresAt       DateTime
  verified        Boolean   @default(false)
  // Pending data stored until verified
  pendingName     String?
  pendingPassword String?
  pendingMeta     Json?     // collegeName, designation, contactNumber, domain

  createdAt       DateTime  @default(now())

  collegeAdminId  String?   @db.ObjectId
  collegeAdmin    CollegeAdmin? @relation(fields: [collegeAdminId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model CollegeBatch {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  collegeAdminId  String    @db.ObjectId
  collegeAdmin    CollegeAdmin @relation(fields: [collegeAdminId], references: [id], onDelete: Cascade)
  name            String    // e.g. "Batch 2026", "CSE 2025"
  department      String?
  graduationYear  Int?
  description     String?
  studentCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  students        CollegeStudent[]

  @@index([collegeAdminId])
}

model CollegeStudent {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  collegeAdminId  String              @db.ObjectId
  collegeAdmin    CollegeAdmin        @relation(fields: [collegeAdminId], references: [id], onDelete: Cascade)
  batchId         String?             @db.ObjectId
  batch           CollegeBatch?       @relation(fields: [batchId], references: [id])
  
  // Linked user (created when student first logs in / onboards)
  userId          String?             @unique @db.ObjectId

  // Student details
  studentName     String
  email           String              @unique
  department      String?
  year            Int?
  rollNumber      String?

  status          CollegeStudentStatus @default(ACTIVE)

  // Plan override (if different from college plan)
  customPlan      Plan?
  customPlanExpiresAt DateTime?

  // Onboarding
  inviteToken     String?             @unique
  inviteSentAt    DateTime?
  onboardedAt     DateTime?
  tempPassword    String?             // hashed temporary password

  adminNotes      String?
  warningFlags    String[]            @default([])

  tags            String[]            @default([])

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([collegeAdminId])
  @@index([status])
}

model CollegePaymentHistory {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  collegeAdminId  String    @db.ObjectId
  collegeAdmin    CollegeAdmin @relation(fields: [collegeAdminId], references: [id], onDelete: Cascade)
  plan            Plan
  seats           Int
  amount          Float
  currency        String    @default("INR")
  status          String    @default("paid") // paid, pending, failed
  invoiceId       String?
  paymentMethod   String?
  validFrom       DateTime
  validTill       DateTime
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([collegeAdminId])
}

model CollegeTransaction {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  collegeAdminId      String    @db.ObjectId
  collegeAdmin        CollegeAdmin @relation(fields: [collegeAdminId], references: [id], onDelete: Cascade)

  // Razorpay
  razorpayOrderId     String    @unique
  razorpayPaymentId   String?
  razorpaySignature   String?

  // Plan details
  plan                Plan
  seats               Int
  pricePerSeat        Float
  subtotal            Float
  couponCode          String?
  couponDiscount      Float     @default(0)
  gstAmount           Float     @default(0)
  finalAmount         Float

  // Student emails to activate on payment
  studentEmails       String[]

  // Status: pending | paid | failed
  status              String    @default("pending")

  // Invoice
  invoiceId           String?
  invoiceUrl          String?

  // Validity period
  validFrom           DateTime?
  validTill           DateTime?

  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([collegeAdminId])
  @@index([status])
}

model CollegeCoupon {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  code            String       @unique
  discountType    DiscountType
  discountValue   Float
  maxUsage        Int?
  usedCount       Int          @default(0)
  expiryDate      DateTime?
  applicablePlans String[]     // empty = apply to all plans
  minSeats        Int?         // minimum seats required
  status          String       @default("active") // active | inactive
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

}

// ─── Notifications ─────────────────────────────────────────────────────────
model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  message     String
  type        String   @default("info") // "info" | "warning" | "success" | "announcement"
  isRead      Boolean  @default(false)
  sentBy      String   // superadmin email or collegeAdminId
  sentByRole  String   // "SUPER_ADMIN" | "COLLEGE_ADMIN"
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── Email Management ───────────────────────────────────────────────────────
model EmailLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  subject     String
  message     String
  recipients  String[] // array of email addresses
  recipientType String  // "single" | "multiple" | "all"
  sentBy      String   // super admin email
  status      String   @default("sent") // "sent" | "failed"
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([sentBy])
}

// ==================== HR & ADMIN PORTAL SYSTEM ====================

// Portal Staff: Admin & HR users managed by Super Admin
model PortalStaff {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  email             String            @unique
  password          String            // bcrypt hashed
  role              PortalRole
  status            PortalStaffStatus @default(ACTIVE)
  department        String?
  phone             String?
  avatar            String?

  // Login security
  loginAttempts     Int               @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?

  // Permissions (granular overrides)
  permissions       Json?             // e.g. {"canDeleteEmployee":true,"canApproveLeave":true}

  // Tokens
  refreshToken      String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?

  // Created by Super Admin
  createdBy         String?           @db.ObjectId
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  employees         Employee[]        @relation("HRAssigned")
  auditLogs         PortalAuditLog[]
  portalEmails      PortalEmailLog[]

  @@index([role, status])
}

// Audit Log for every action in portal
model PortalAuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  staffId     String?  @db.ObjectId
  staff       PortalStaff? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  actorEmail  String
  actorRole   String
  action      String   // e.g. "CREATE_EMPLOYEE", "APPROVE_LEAVE", "DELETE_HR"
  entityType  String?  // e.g. "Employee", "Candidate", "PortalStaff"
  entityId    String?
  metadata    Json?    // before/after snapshot or extra info
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
}

// Email templates
model EmailTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  subject     String
  htmlBody    String
  textBody    String?
  variables   String[] // list of template variable names e.g. ["{{name}}","{{date}}"]
  type        String   // "HR" | "ADMIN" | "SYSTEM"
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Portal-specific email log (separate from main EmailLog)
model PortalEmailLog {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  staffId      String?           @db.ObjectId
  staff        PortalStaff?      @relation(fields: [staffId], references: [id], onDelete: SetNull)
  senderEmail  String
  senderRole   String            // "ADMIN" | "HR" | "SUPER_ADMIN"
  recipientEmail String
  subject      String
  body         String
  templateId   String?           @db.ObjectId
  attachments  Json?             // array of {name, url}
  status       PortalEmailStatus @default(PENDING)
  errorMsg     String?
  retryCount   Int               @default(0)
  sentAt       DateTime?
  createdAt    DateTime          @default(now())

  @@index([senderEmail])
  @@index([recipientEmail])
  @@index([status])
  @@index([createdAt])
}

// Employee (managed by HR)
model Employee {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  employeeCode    String          @unique
  name            String
  email           String          @unique
  phone           String?
  department      String
  designation     String
  joinDate        DateTime
  salary          Float?
  status          EmployeeStatus  @default(ACTIVE)

  // Linked HR
  hrId            String?         @db.ObjectId
  hr              PortalStaff?    @relation("HRAssigned", fields: [hrId], references: [id], onDelete: SetNull)

  address         String?
  emergencyContact String?
  avatar          String?
  resumeUrl       String?
  documents       Json?           // array of {name, url, type}

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  leaveRequests   LeaveRequest[]
  attendances     Attendance[]
  payrollRecords  PayrollRecord[]
  offerLetters    OfferLetter[]

  @@index([hrId, status])
  @@index([department])
}

// Candidate (job applicants managed by HR)
model Candidate {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String
  phone           String?
  position        String
  department      String?
  status          CandidateStatus @default(APPLIED)

  // Resume & documents
  resumeUrl       String?
  documents       Json?

  // Interview details
  interviewDate   DateTime?
  interviewNotes  String?
  interviewerName String?

  // HR assigned
  hrId            String?         @db.ObjectId
  source          String?         // LinkedIn, Referral, Job Portal, etc.
  expectedSalary  Float?
  currentSalary   Float?
  experience      Int?            // years
  skills          String[]

  offerLetters    OfferLetter[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([hrId])
}

// Offer Letter generated for candidates or employees
model OfferLetter {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  candidateId     String?     @db.ObjectId
  candidate       Candidate?  @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  employeeId      String?     @db.ObjectId
  employee        Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  position        String
  department      String
  salary          Float
  joiningDate     DateTime
  content         String      // HTML content of offer letter
  pdfUrl          String?

  issuedBy        String      // HR email
  acceptedAt      DateTime?
  status          String      @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// Leave Request
model LeaveRequest {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  employeeId      String      @db.ObjectId
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type            LeaveType
  startDate       DateTime
  endDate         DateTime
  days            Int
  reason          String
  status          LeaveStatus @default(PENDING)

  approvedBy      String?     // HR/Admin email
  approvedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([employeeId, status])
  @@index([startDate, endDate])
}

// Attendance
model Attendance {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  employeeId      String      @db.ObjectId
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date            DateTime
  checkIn         DateTime?
  checkOut        DateTime?
  hoursWorked     Float?
  status          String      @default("PRESENT") // PRESENT | ABSENT | HALF_DAY | ON_LEAVE
  notes           String?

  markedBy        String?     // HR email

  createdAt       DateTime    @default(now())

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Payroll
model PayrollRecord {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  employeeId      String      @db.ObjectId
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month           Int         // 1-12
  year            Int
  basicSalary     Float
  allowances      Float       @default(0)
  deductions      Float       @default(0)
  netSalary       Float
  status          String      @default("PENDING") // PENDING | PROCESSED | PAID
  paymentDate     DateTime?
  notes           String?

  processedBy     String?     // HR email

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([employeeId, month, year])
  @@index([employeeId])
}

// Support Ticket (managed by Admin)
model SupportTicket {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  ticketNumber    String          @unique
  title           String
  description     String
  submittedBy     String          // user email or staff email
  submittedByRole String          // user, hr, admin
  assignedTo      String?         // admin email
  status          TicketStatus    @default(OPEN)
  priority        TicketPriority  @default(MEDIUM)
  category        String?         // billing, technical, general, hr
  resolution      String?
  attachments     Json?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, priority])
  @@index([submittedBy])
}

// Feature Toggle (managed by Admin)
model FeatureToggle {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Portal Session / Refresh Token store
model PortalRefreshToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  staffId     String   @db.ObjectId
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([staffId])
  @@index([expiresAt])
}